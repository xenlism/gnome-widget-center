{
  "id": "clock",
  "name": "Clock",
  "description": "Shows the current time and date on the desktop.",
  "version": "1.0.0",
  "author": "gnome-widget-center",
  "api-version": 1,
  "entry": "widget.js",
  "prefs": "prefs.js",
  "block-size": { "cols": 20, "rows": 10 },
  "default-position": { "x": 300, "y": 400, "monitor": 0 },
  "size-constraints": { "minCols": 7, "minRows": 4, "maxCols": 31, "maxRows": 31 }
}
